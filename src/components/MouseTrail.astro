---
import { getIconData, iconToSVG } from '@iconify/utils'
import logosIconSet from '@iconify-json/logos/icons.json'

type LogoItem = { svg: string; alt: string }

// 图标名称来自 https://icones.js.org/collection/logos
const logoNames: Array<[string, string]> = [
  ['javascript', 'JavaScript'],
  ['typescript-icon', 'TypeScript'],
  ['vue', 'Vue'],
  ['astro', 'Astro'],
  ['nuxt-icon', 'Nuxt'],
  ['nextjs-icon', 'Next.js'],
  ['nodejs-icon', 'Node.js'],
  ['tailwindcss-icon', 'Tailwind CSS'],
  ['react', 'React'],
  ['html-5', 'HTML'],
  ['css-3', 'CSS'],
  ['github-icon', 'GitHub'],
  ['bilibili', 'Bilibili'],
]

function buildSVG(name: string): string {
  // eslint-disable-next-line @typescript-eslint/no-explicit-any
  const iconData = getIconData(logosIconSet as any, name)
  if (!iconData) return ''
  const { attributes, body } = iconToSVG(iconData, { width: '1em', height: '1em' })
  const attrsStr = Object.entries(attributes)
    .map(([k, v]) => `${k}="${v}"`)
    .join(' ')
  return `<svg ${attrsStr}>${body}</svg>`
}

const logoItems: LogoItem[] = logoNames
  .map(([name, alt]) => ({ svg: buildSVG(name), alt }))
  .filter(item => item.svg !== '')
---

<script is:inline define:vars={{ logoItems }}>
  // 将构建时数据挂载到 window，供 mouseTrail.ts 读取
  window.__mouseTrailLogos = logoItems
</script>

<script>
  import '../scripts/mouseTrail'
</script>

<style is:global>
  @keyframes mouse-trail-float {
    0% {
      opacity: 1;
      transform: translate(-50%, -50%) translateY(0) translateX(0) scale(1);
    }
    100% {
      opacity: 0;
      transform: translate(-50%, -50%) translateY(-60px) translateX(var(--drift-x)) scale(0.4);
    }
  }
</style>
