---
---
<div id="art-plum" class="fixed top-0 bottom-0 left-0 right-0 pointer-events-none print:hidden dark:invert" style="z-index: -1; mask-image: radial-gradient(circle, transparent, black); -webkit-mask-image: radial-gradient(circle, transparent, black);">
  <canvas id="art-plum-canvas" width="400" height="400"></canvas>
</div>

<script>
  function initCanvas(canvas: HTMLCanvasElement) {
    const ctx = canvas.getContext('2d')!
    const dpr = window.devicePixelRatio || 1
    // eslint-disable-next-line @typescript-eslint/no-explicit-any
    const bsr = (ctx as any).webkitBackingStorePixelRatio || (ctx as any).mozBackingStorePixelRatio || (ctx as any).msBackingStorePixelRatio || (ctx as any).oBackingStorePixelRatio || (ctx as any).backingStorePixelRatio || 1
    const dpi = dpr / bsr
    const width = window.innerWidth
    const height = window.innerHeight

    canvas.style.width = `${width}px`
    canvas.style.height = `${height}px`
    canvas.width = dpi * width
    canvas.height = dpi * height
    ctx.scale(dpi, dpi)

    return { ctx, width, height }
  }

  function polar2cart(x: number, y: number, r: number, theta: number) {
    return [x + r * Math.cos(theta), y + r * Math.sin(theta)]
  }

  function randomMiddle() {
    return Math.random() * 0.6 + 0.2
  }

  document.addEventListener('astro:page-load', () => {
    const container = document.getElementById('art-plum')
    const canvas = document.getElementById('art-plum-canvas') as HTMLCanvasElement
    if (!container || !canvas) return

    const r180 = Math.PI
    const r90 = Math.PI / 2
    const r15 = Math.PI / 12
    const color = '#88888825'
    const MIN_BRANCH = 30
    const len = 6
    const { random } = Math

    let steps: Array<() => void> = []
    let prevSteps: Array<() => void> = []
    let lastTime = 0
    const interval = 1000 / 40 // 50fps
    let animationId: number | null = null
    let stopped = false

    function step(
      x: number,
      y: number,
      rad: number,
      counter: { value: number } = { value: 0 }
    ) {
      const length = random() * len
      counter.value += 1

      const [nx, ny] = polar2cart(x, y, length, rad)

      const ctx = canvas.getContext('2d')!
      ctx.beginPath()
      ctx.moveTo(x, y)
      ctx.lineTo(nx, ny)
      ctx.stroke()

      const rad1 = rad + random() * r15
      const rad2 = rad - random() * r15

      const size = { width: window.innerWidth, height: window.innerHeight }

      if (nx < -100 || nx > size.width + 100 || ny < -100 || ny > size.height + 100)
        return

      const rate = counter.value <= MIN_BRANCH ? 0.8 : 0.5

      if (random() < rate)
        steps.push(() => step(nx, ny, rad1, counter))

      if (random() < rate)
        steps.push(() => step(nx, ny, rad2, counter))
    }

    function start() {
      const { ctx, width, height } = initCanvas(canvas)
      ctx.lineWidth = 1
      ctx.strokeStyle = color
      prevSteps = []
      steps = [
        () => step(randomMiddle() * width, -5, r90),
        () => step(randomMiddle() * width, height + 5, -r90),
        () => step(-5, randomMiddle() * height, 0),
        () => step(width + 5, randomMiddle() * height, r180),
      ]
      if (width < 500)
        steps = steps.slice(0, 2)
      stopped = false
      if (animationId !== null) cancelAnimationFrame(animationId)
      loop()
    }

    function loop() {
      if (stopped) return

      if (performance.now() - lastTime < interval) {
        animationId = requestAnimationFrame(loop)
        return
      }

      lastTime = performance.now()
      prevSteps = steps
      steps = []

      if (!prevSteps.length) {
        stopped = true
        return
      }

      prevSteps.forEach((i) => {
        if (random() < 0.5)
          steps.push(i)
        else
          i()
      })

      animationId = requestAnimationFrame(loop)
    }

    start()

    const resizeObserver = new ResizeObserver(() => {
      if (animationId !== null) cancelAnimationFrame(animationId)
      start()
    })
    resizeObserver.observe(document.documentElement)
  })
</script>
